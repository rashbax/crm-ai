# Copy to .env.local — never commit this file!

# NextAuth (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
NEXTAUTH_SECRET=REPLACE_ME
NEXTAUTH_URL=http://localhost:3000

# Credential encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=REPLACE_ME_DIFFERENT_VALUE

# App mode
# DRY_RUN=1 -> demo data only
# REAL_API=1 -> real marketplace API calls enabled
DRY_RUN=0
REAL_API=1
